{
  "compilerOptions": {
    "target": "ESNext",                                  /* Versão moderna do JS */
    "module": "CommonJS",                                /* Padrão de ouro para Node.js/Render */
    "moduleResolution": "node",
    "outDir": "./dist",                                  /* Onde o código JS será gerado */
    "rootDir": "./",                                     /* Onde está seu server.ts */
    
    "strict": true,                                      /* Ativa checagem rigorosa de erros */
    "esModuleInterop": true,                             /* Permite importar Express/Cors sem erros */
    "skipLibCheck": true,                                /* Pula checagem de bibliotecas externas (mais rápido) */
    "forceConsistentCasingInFileNames": true,            /* Evita erro de letras maiúsculas/minúsculas no Windows */
    
    "sourceMap": true,                                   /* Ajuda a debugar se der erro */
    "declaration": true                                  /* Gera arquivos de definição de tipos */
  },
  "include": ["**/*.ts"],                                /* Inclui todos os arquivos .ts */
  "exclude": ["node_modules"]                            /* Ignora a pasta pesada */
}

